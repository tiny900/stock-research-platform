# LLM Provider Configuration
LLM_PROVIDER=openai          # openai | deepseek | anthropic
LLM_MODEL=gpt-4o-mini        # Model name
OPENAI_API_KEY=your-key-here  # Required for OpenAI/DeepSeek
ANTHROPIC_API_KEY=             # Required for Anthropic
LLM_BASE_URL=                 # Optional: custom API base URL (e.g., https://api.deepseek.com)
LLM_TEMPERATURE=0.7           # LLM temperature (0.0-1.0)

# Prompt Engineering
PROMPT_VERSION=v3_cot_rag     # v1_basic | v2_structured | v3_cot_rag

# RAG Configuration
KNOWLEDGE_BASE_PATH=data/knowledge_base
CHROMA_PERSIST_DIR=data/chroma_db
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=3
